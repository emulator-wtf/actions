{
  "name": "@emulator-wtf/actions",
  "version": "0.0.1",
  "description": "emulator.wtf GitHub actions",
  "type": "module",
  "scripts": {
    "build": "rimraf dist && tsc --noEmit && rollup -c",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "prettier": "prettier src --check",
    "prettier-fix": "prettier src --write"
  },
  "homepage": "https://github.com/emulator-wtf/actions",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.12.2",
    "eslint": "^9.39.2",
    "eslint-config-love": "^153.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "rimraf": "^6.1.2",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  }
}
